{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "maine",
	"version": "0.1.0",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "concurrently \"pnpm --filter @maine/frontend dev:https\" \"pnpm --filter @maine/backend start:dev\"",
		"start": "pnpm --filter @maine/frontend build && pnpm --filter @maine/frontend start",
		"knip": "knip",
		"postinstall": "pnpm lefthook install",
		"service:install": "pnpm --filter @maine/backend service:install",
		"service:start": "pnpm --filter @maine/backend service:start",
		"service:stop": "pnpm --filter @maine/backend service:stop",
		"service:restart": "pnpm --filter @maine/backend service:restart",
		"service:status": "pnpm --filter @maine/backend service:status",
		"service:uninstall": "pnpm --filter @maine/backend service:uninstall"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"concurrently": "^9.2.1",
		"knip": "^5.60.2",
		"lefthook": "^1.11.13",
		"typescript": "^5.8.3"
	},
	"engines": {
		"node": "24.11.0",
		"pnpm": ">=8.0.0"
	},
	"packageManager": "pnpm@10.18.0"
}
